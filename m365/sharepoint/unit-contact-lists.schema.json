{
  "version": "2026-03-11",
  "site": {
    "name": "ISMS-Forms",
    "purpose": "ISMS unit contact application, approval, account handoff, and audit backend"
  },
  "lists": [
    {
      "name": "UnitContactApplications",
      "description": "Public-facing applications for new unit information security contacts in the A3-ready workflow",
      "recommendedIndexes": ["ApplicationId", "ApplicantEmail", "UnitCode", "Status", "SubmittedAt"],
      "columns": [
        { "name": "Title", "type": "singleLineText", "required": true, "notes": "Use ApplicationId as the display title" },
        { "name": "ApplicationId", "type": "singleLineText", "required": true, "unique": true },
        { "name": "ApplicantName", "type": "singleLineText", "required": true },
        { "name": "ApplicantEmail", "type": "singleLineText", "required": true },
        { "name": "ExtensionNumber", "type": "singleLineText", "required": true },
        { "name": "UnitCategory", "type": "choice", "required": true, "choices": ["行政單位", "學術單位", "研究中心"] },
        { "name": "PrimaryUnitCode", "type": "singleLineText", "required": true },
        { "name": "PrimaryUnitName", "type": "singleLineText", "required": true },
        { "name": "SecondaryUnitCode", "type": "singleLineText", "required": false },
        { "name": "SecondaryUnitName", "type": "singleLineText", "required": false },
        { "name": "UnitCode", "type": "singleLineText", "required": true, "notes": "Normalized final unit code used by app authorization" },
        { "name": "UnitValue", "type": "singleLineText", "required": true, "notes": "Normalized full unit label shown in frontend" },
        { "name": "ContactType", "type": "choice", "required": true, "choices": ["primary", "backup"] },
        { "name": "Status", "type": "choice", "required": true, "choices": ["pending_review", "returned", "approved", "rejected", "activation_pending", "active"] },
        { "name": "SubmittedAt", "type": "dateTime", "required": true },
        { "name": "ReviewedAt", "type": "dateTime", "required": false },
        { "name": "ReviewedBy", "type": "singleLineText", "required": false },
        { "name": "ReviewComment", "type": "multipleLinesText", "required": false },
        { "name": "ActivationSentAt", "type": "dateTime", "required": false, "notes": "For A3 V1 this means account handoff notice sent" },
        { "name": "ActivatedAt", "type": "dateTime", "required": false },
        { "name": "ProvisionedAt", "type": "dateTime", "required": false, "notes": "When the app account or login path was prepared by admin" },
        { "name": "ProvisionedBy", "type": "singleLineText", "required": false },
        { "name": "ProvisioningNote", "type": "multipleLinesText", "required": false, "notes": "How the applicant should complete first sign-in or password reset" },
        { "name": "AppUsername", "type": "singleLineText", "required": false, "notes": "Current app username if the A3 flow issues a local account" },
        { "name": "ExternalUserId", "type": "singleLineText", "required": false, "notes": "Reserved for future Azure / External ID upgrade" },
        { "name": "Source", "type": "choice", "required": true, "choices": ["frontend", "manual", "migration"] },
        { "name": "BackendMode", "type": "choice", "required": true, "choices": ["local-emulator", "sharepoint-flow", "m365-api"] },
        { "name": "Note", "type": "multipleLinesText", "required": false }
      ]
    },
    {
      "name": "UnitAdmins",
      "description": "Active or pending contact identities bound to a unit",
      "recommendedIndexes": ["Email", "UnitCode", "Status", "ExternalUserId", "AppUsername"],
      "columns": [
        { "name": "Title", "type": "singleLineText", "required": true, "notes": "DisplayName or Email" },
        { "name": "ExternalUserId", "type": "singleLineText", "required": false },
        { "name": "DisplayName", "type": "singleLineText", "required": true },
        { "name": "Email", "type": "singleLineText", "required": true },
        { "name": "AppUsername", "type": "singleLineText", "required": false, "notes": "Current app username in the A3-ready version" },
        { "name": "ExtensionNumber", "type": "singleLineText", "required": false },
        { "name": "UnitCode", "type": "singleLineText", "required": true },
        { "name": "UnitName", "type": "singleLineText", "required": true },
        { "name": "ContactType", "type": "choice", "required": true, "choices": ["primary", "backup"] },
        { "name": "Status", "type": "choice", "required": true, "choices": ["pending_activation", "active", "disabled", "revoked"] },
        { "name": "ActivatedAt", "type": "dateTime", "required": false },
        { "name": "LastLoginAt", "type": "dateTime", "required": false },
        { "name": "LastApplicationId", "type": "singleLineText", "required": false }
      ]
    },
    {
      "name": "OpsAudit",
      "description": "Operational and security audit trail for application, review, activation, and maintenance actions",
      "recommendedIndexes": ["EventType", "ActorEmail", "TargetEmail", "UnitCode", "OccurredAt"],
      "columns": [
        { "name": "Title", "type": "singleLineText", "required": true, "notes": "Human-readable event title" },
        { "name": "EventType", "type": "singleLineText", "required": true },
        { "name": "ActorEmail", "type": "singleLineText", "required": false },
        { "name": "TargetEmail", "type": "singleLineText", "required": false },
        { "name": "UnitCode", "type": "singleLineText", "required": false },
        { "name": "RecordId", "type": "singleLineText", "required": false },
        { "name": "OccurredAt", "type": "dateTime", "required": true },
        { "name": "PayloadJson", "type": "multipleLinesText", "required": false, "notes": "Compact JSON payload for troubleshooting" }
      ]
    }
  ]
}
